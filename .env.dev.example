# Copy this file to .env.dev and update values.

FIREBASE_PROJECT_ID=matsuhisa-japan-homepage
GOOGLE_APPLICATION_CREDENTIALS=/workspace/hanko-field-firebase-adminsdk-fbsvc.json
API_FIREBASE_CREDENTIALS_FILE=/workspace/hanko-field-firebase-adminsdk-fbsvc.json

API_FIRESTORE_PROJECT_ID=matsuhisa-japan-homepage
API_STORAGE_ASSETS_BUCKET=local-assets
API_GEMINI_API_KEY=<your-gemini-api-key>
API_GEMINI_MODEL=gemini-2.5-flash-lite
API_PSP_STRIPE_API_KEY=<your-stripe-secret-key>
API_PSP_STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
API_PSP_STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3052/payment/success?session_id={CHECKOUT_SESSION_ID}
API_PSP_STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3052/payment/failure

HANKO_ADMIN_MODE=dev
HANKO_ADMIN_LOCALE=ja
HANKO_ADMIN_FIREBASE_PROJECT_ID_DEV=matsuhisa-japan-homepage
HANKO_ADMIN_FIREBASE_CREDENTIALS_FILE_DEV=/workspace/hanko-field-firebase-adminsdk-fbsvc.json
HANKO_ADMIN_STORAGE_ASSETS_BUCKET_DEV=local-assets

HANKO_WEB_MODE=dev
HANKO_WEB_LOCALE=ja
HANKO_WEB_API_BASE_URL=http://localhost:3050
HANKO_WEB_FIREBASE_PROJECT_ID_DEV=matsuhisa-japan-homepage
HANKO_WEB_FIREBASE_CREDENTIALS_FILE_DEV=/workspace/hanko-field-firebase-adminsdk-fbsvc.json
HANKO_WEB_STORAGE_ASSETS_BUCKET_DEV=local-assets
