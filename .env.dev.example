# Copy this file to .env.dev and update values.
# Firestore / Auth use Google ADC. Run `gcloud auth application-default login`
# before starting the app or Docker workspace.

FIREBASE_PROJECT_ID=hanko-field

API_FIRESTORE_PROJECT_ID=hanko-field
API_STORAGE_ASSETS_BUCKET=hanko-field-dev
API_GEMINI_API_KEY=<your-gemini-api-key>
API_GEMINI_MODEL=gemini-2.5-flash-lite
API_PSP_STRIPE_API_KEY=<your-stripe-secret-key>
API_PSP_STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
API_PSP_STRIPE_CHECKOUT_SUCCESS_URL=http://127.0.0.1:3052/payment/success?session_id={CHECKOUT_SESSION_ID}
API_PSP_STRIPE_CHECKOUT_CANCEL_URL=http://127.0.0.1:3052/payment/failure
STRIPE_WEBHOOK_URL=http://localhost:3050/v1/payments/stripe/webhook

HANKO_ADMIN_MODE=dev
HANKO_ADMIN_LOCALE=ja
HANKO_ADMIN_FIREBASE_PROJECT_ID_DEV=hanko-field
HANKO_ADMIN_STORAGE_ASSETS_BUCKET_DEV=hanko-field-dev

HANKO_WEB_MODE=dev
HANKO_WEB_LOCALE=en
HANKO_WEB_DEFAULT_LOCALE=en
HANKO_WEB_SITE_BASE_URL=http://localhost:3052
HANKO_WEB_SITE_BASE_URL=http://127.0.0.1:3052
HANKO_WEB_API_BASE_URL=http://127.0.0.1:3050
HANKO_WEB_FIREBASE_PROJECT_ID_DEV=hanko-field
HANKO_WEB_STORAGE_ASSETS_BUCKET_DEV=hanko-field-dev
