# Copy this file to .env.prod and update values.
# Firestore / Storage use Google ADC. Run `gcloud auth application-default login`
# before starting the app or Docker workspace.

FIREBASE_PROJECT_ID=hanko-field-prod

API_FIRESTORE_PROJECT_ID=hanko-field-prod
API_STORAGE_ASSETS_BUCKET=hanko-field-prod.firebasestorage.app
API_GEMINI_API_KEY=<your-gemini-api-key>
API_GEMINI_MODEL=gemini-2.5-flash-lite
API_PSP_STRIPE_API_KEY=<your-stripe-live-secret-key>
API_PSP_STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
API_PSP_STRIPE_CHECKOUT_SUCCESS_URL=https://<your-web-domain>/payment/success?session_id={CHECKOUT_SESSION_ID}
API_PSP_STRIPE_CHECKOUT_CANCEL_URL=https://<your-web-domain>/payment/failure

HANKO_ADMIN_MODE=prod
HANKO_ADMIN_LOCALE=ja
HANKO_ADMIN_FIREBASE_PROJECT_ID_PROD=hanko-field-prod
HANKO_ADMIN_STORAGE_ASSETS_BUCKET_PROD=hanko-field-prod.firebasestorage.app
HANKO_ADMIN_LOGIN_PASSPHRASE_PROD=<your-admin-login-passphrase>

HANKO_WEB_MODE=prod
HANKO_WEB_LOCALE=en
HANKO_WEB_DEFAULT_LOCALE=en
HANKO_WEB_SITE_BASE_URL=https://<your-web-domain>
HANKO_WEB_API_BASE_URL=https://<your-api-cloud-run-url>
HANKO_WEB_FIREBASE_PROJECT_ID_PROD=hanko-field-prod
HANKO_WEB_STORAGE_ASSETS_BUCKET_PROD=hanko-field-prod.firebasestorage.app
HANKO_WEB_ADMIN_BASE_URL_PROD=https://<your-admin-cloud-run-url>
